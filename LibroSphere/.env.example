ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
AllowedHosts=*
Swagger__Enabled=true
API_HTTP_PORT=8080
DB_HOST=localhost
DB_PORT=1433
DB_NAME=LibroSphere
DB_USER=sa
DB_SA_PASSWORD=YourStrong!Pass123

ConnectionStrings__Redis=localhost:6379,abortConnect=false

RabbitMQ__Host=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest

StripeSettings__PublishableKey=pk_test_your_publishable_key
StripeSettings__SecretKey=sk_test_your_secret_key
StripeSettings__WhSecret=whsec_your_webhook_secret

JwtSettings__SecretKey=replace_with_a_long_random_jwt_secret
JwtSettings__Issuer=LibroSphere
JwtSettings__Audience=LibroSphere.Clients
JwtSettings__ExpiryMinutes=120
JwtSettings__RefreshExpiryDays=7

CloudflareR2__AccountEndpoint=https://your-account-id.r2.cloudflarestorage.com
CloudflareR2__BucketName=librosphere
CloudflareR2__AccessKeyId=your_r2_access_key_id
CloudflareR2__SecretAccessKey=your_r2_secret_access_key
CloudflareR2__SignedUrlMinutes=30

AccessControl__AdminEmails__0=admin@librosphere.local
AccessControl__SeedDefaultAdmin=true
AccessControl__DefaultAdminFirstName=Desktop
AccessControl__DefaultAdminLastName=Admin
AccessControl__DefaultAdminEmail=admin@librosphere.local
AccessControl__DefaultAdminPassword=Admin123!
AccessControl__SeedDefaultUser=true
AccessControl__DefaultUserFirstName=Mobile
AccessControl__DefaultUserLastName=User
AccessControl__DefaultUserEmail=user@librosphere.local
AccessControl__DefaultUserPassword=User123!

Email__Host=smtp.gmail.com
Email__Port=587
Email__EnableSsl=true
Email__Username=your-gmail-address@gmail.com
Email__Password=your-16-char-gmail-app-password
Email__FromEmail=your-gmail-address@gmail.com
Email__FromName=LibroSphere

Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.Hosting.Lifetime=Information
Logging__LogLevel__MassTransit=Information
